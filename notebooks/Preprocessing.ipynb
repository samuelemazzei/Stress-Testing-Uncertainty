   "metadata": {},
   "outputs": [],
   "source": [
    "cat_mode = ['depr', 'fatigue', 'appetite','concen','phactiv', 'alcohol',\n",
    "       'heart_attack', 'stroke', 'diabetes', 'cancer', 'astar',\n",
    "       'drug_hbp','drug_sleep','drug_stom','drug_inf','drug_oth']\n",
    "for var in cat_mode:\n",
    "    if df_imp[var].isna().any():\n",
    "        mode_val = df_imp[var].mode(dropna=True)[0]\n",
    "        df_imp[var] = df_imp[var].fillna(mode_val)\n",
    "\n",
    "df_imp = df_imp.drop('smoke',axis=1)\n",
    "df_imp[cat_tot] = df_imp[cat_tot].astype(int)"
   ]
