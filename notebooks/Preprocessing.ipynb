   "metadata": {},
   "outputs": [],
   "source": [
    "cat_tot = ['depr','appetite','concen','fatigue','phactiv',\n",
    "           'drug_hbp','drug_stom','drug_sleep','drug_inf','drug_oth','alcohol','gender','astar']\n",
    "\n",
    "num_tot = ['bmi','maxgrip','age','chol','crp','trigl','cyst_c','hdl','thb','a1c']"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "ec49e1b2",
   "metadata": {},
   "source": [
    "**MULTIPLE IMPUTATION:**"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "6eb00fd1",
   "metadata": {},
   "outputs": [],
   "source": [
    "df_m = df_sub.copy()\n",
    "from sklearn.experimental import enable_iterative_imputer\n",
    "from sklearn.impute import IterativeImputer\n",
    "\n",
    "biomarks = ['chol','crp','trigl','cyst_c','hdl','thb','a1c']\n",
    "\n",
    "imputed_datasets = []\n",
    "\n",
    "for seed in range(5):\n",
    "    imp = IterativeImputer(max_iter=20, random_state=seed, sample_posterior=True)\n",
    "    df_tmp = df_m.copy()\n",
    "    df_tmp[biomarks] = imp.fit_transform(df_tmp[biomarks])\n",
    "    imputed_datasets.append(df_tmp)\n",
    "\n",
    "stacked = np.stack([df[biomarks].values for df in imputed_datasets], axis=0)\n",
    "mean_values = stacked.mean(axis=0)\n",
    "\n",
    "df_imp = df_m.copy()\n",
    "df_imp[biomarks] = mean_values"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "8427484e",
   "metadata": {},
   "outputs": [],
   "source": [
    "df_imp ['age'] = df_imp ['age'].astype(str)\n",
    "df_imp ['age'] = pd.to_numeric(df_imp ['age'], errors='coerce')\n",
    "\n",
    "df_imp ['maxgrip'] = df_imp ['maxgrip'].astype(str)\n",
    "df_imp ['maxgrip'] = pd.to_numeric(df_imp ['maxgrip'], errors='coerce')\n",
    "\n",
    "df_imp ['bmi'] = df_imp ['bmi'].astype(str)\n",
    "df_imp ['bmi'] = pd.to_numeric(df_imp ['bmi'], errors='coerce')\n",
    "\n",
    "df_imp.isna().sum()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "55d52ead",
   "metadata": {},
   "outputs": [],
   "source": [
    "df_imp.groupby([\"gender\"])[[\"bmi\", \"maxgrip\"]].skew()\n",
    "\n",
    "df_imp[\"bmi\"] = df_imp.groupby(\"gender\")[\"bmi\"]\\\n",
    "                      .transform(lambda x: x.fillna(x.median()))\n",
    "\n",
    "df_imp[\"maxgrip\"] = df_imp.groupby(\"gender\")[\"maxgrip\"]\\\n",
    "                      .transform(lambda x: x.fillna(x.mean()))\n",
    "df_imp.info()"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "c4ee1238",
   "metadata": {},
   "source": [
    "**IMPOSSIBLE VALUES and RARE VALUES**\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "0230ee0c",
   "metadata": {},
   "outputs": [],
   "source": [
    "cat_mode = ['depr', 'fatigue', 'appetite','concen','phactiv', 'alcohol',\n",
    "       'heart_attack', 'stroke', 'diabetes', 'cancer', 'astar',\n",
    "       'drug_hbp','drug_sleep','drug_stom','drug_inf','drug_oth']\n",
    "for var in cat_mode:\n",
    "    if df_imp[var].isna().any():\n",
    "        mode_val = df_imp[var].mode(dropna=True)[0]\n",
    "        df_imp[var] = df_imp[var].fillna(mode_val)\n",
    "\n",
    "df_imp = df_imp.drop('smoke',axis=1)\n",
    "df_imp[cat_tot] = df_imp[cat_tot].astype(int)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "8994b0a7",
   "metadata": {},
   "outputs": [],
   "source": [
    "numeric = ['age','chol','crp','trigl','cyst_c','hdl','thb','a1c','bmi','maxgrip']\n",
    "df_imp[numeric].describe()\n",
    "#from scipy import stats\n",
    "#df_numeric_std = df_imp[['crp','trigl','bmi','maxgrip']].apply(stats.zscore)\n",
    "\n",
    "#sns.boxplot(data=df_numeric_std)\n",
