   "outputs": [],
   "source": [
    "print((df_imp['crp'] < 0).sum()) #impossible\n",
    "print((df_imp['trigl'] > 2000).sum()) #rare\n",
    "print((df_imp['bmi'] > 50).sum())\n",
    "\n",
    "print(df_imp[['crp']].quantile([0.0025]))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "76e4b39f",
   "metadata": {},
   "outputs": [],
   "source": [
    "from scipy.stats.mstats import winsorize\n",
    "df_win = df_imp.copy()\n",
    "crp_win = winsorize(df_imp['crp'], limits=[0.0025, 0])\n",
    "df_win['crp'] = crp_win"
   ]
  },
  {
