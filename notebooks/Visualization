    "from scipy.stats import norm\n",
    "bmi_m = df_final[df_final[\"gender\"] == 1][\"bmi\"]\n",
    "bmi_f = df_final[df_final[\"gender\"] == 0][\"bmi\"]\n",
    "mg_m = df_final[df_final[\"gender\"] == 1][\"maxgrip\"]\n",
    "mg_f = df_final[df_final[\"gender\"] == 0][\"maxgrip\"]\n",
    "\n",
    "fig, axes = plt.subplots(2, 2, figsize=(10, 6))\n",
    "fig.suptitle('BMI and Maxgrip by Gender', fontsize=12, fontweight='bold')\n",
    "\n",
    "# colors\n",
    "blue = '#1f77b4'\n",
    "red = '#d62728'\n",
    "\n",
    "# ----- BMI_M -----\n",
    "bmi_avg_m = np.mean(bmi_m)\n",
    "bmi_std_m = np.std(bmi_m, ddof=1)\n",
    "\n",
    "axes[0,0].hist(bmi_m, bins=30, density=True, alpha=0.5, color=blue)\n",
    "x_m = np.linspace(min(bmi_m), max(bmi_m), 100)\n",
    "axes[0,0].plot(x_m, norm.pdf(x_m, bmi_avg_m, bmi_std_m), color=blue, linewidth=2)\n",
    "axes[0,0].set_title(\"Male\", fontweight='bold')\n",
    "axes[0,0].set_xlabel(\"BMI\")\n",
    "axes[0,0].set_ylabel(\"Density\")\n",
    "axes[0,0].axvline(bmi_avg_m, color=blue, linestyle='--', alpha=0.7)\n",
    "\n",
    "# ----- BMI_F -----\n",
    "bmi_avg_f = np.mean(bmi_f)\n",
    "bmi_std_f = np.std(bmi_f, ddof=1)\n",
    "\n",
    "axes[0,1].hist(bmi_f, bins=30, density=True, alpha=0.5, color=red)\n",
    "x_f = np.linspace(min(bmi_f), max(bmi_f), 100)\n",
    "axes[0,1].plot(x_f, norm.pdf(x_f, bmi_avg_f, bmi_std_f), color=red, linewidth=2)\n",
    "axes[0,1].set_title(\"Female\",fontweight='bold')\n",
    "axes[0,1].set_xlabel(\"BMI\")\n",
    "axes[0,1].set_ylabel(\"Density\")\n",
    "axes[0,1].axvline(bmi_avg_f, color=red, linestyle='--', alpha=0.7)\n",
    "\n",
    "# ----- GRIP_M -----\n",
    "mg_avg_m = np.mean(mg_m)\n",
    "mg_std_m = np.std(mg_m, ddof=1)\n",
    "\n",
    "axes[1,0].hist(mg_m, bins=30, density=True, alpha=0.5, color=blue)\n",
    "x_mg = np.linspace(min(mg_m), max(mg_m), 100)\n",
    "axes[1,0].plot(x_mg, norm.pdf(x_mg, mg_avg_m, mg_std_m), color=blue, linewidth=2)\n",
    "axes[1,0].set_xlabel(\"Maxgrip (kg)\")\n",
    "axes[1,0].set_ylabel(\"Density\")\n",
    "axes[1,0].axvline(mg_avg_m, color=blue, linestyle='--', alpha=0.7)\n",
    "\n",
    "# ----- GRIP_F -----\n",
    "mg_avg_f = np.mean(mg_f)\n",
    "mg_std_f = np.std(mg_f, ddof=1)\n",
    "\n",
    "axes[1,1].hist(mg_f, bins=30, density=True, alpha=0.5, color=red)\n",
    "x_fg = np.linspace(min(mg_f), max(mg_f), 100)\n",
    "axes[1,1].plot(x_fg, norm.pdf(x_fg, mg_avg_f, mg_std_f), color=red, linewidth=2)\n",
    "axes[1,1].set_xlabel(\"Maxgrip (kg)\")\n",
    "axes[1,1].set_ylabel(\"Density\")\n",
    "axes[1,1].axvline(mg_avg_f, color=red, linestyle='--', alpha=0.7)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('distribuzione_bmi_grip.pdf',\n",
    "            bbox_inches='tight',\n",
    "            dpi=300,\n",
    "            format='pdf',\n",
    "            facecolor='white',\n",
    "            edgecolor='none')\n",
    "plt.show()\n",
    "\n"
   ]
  }
